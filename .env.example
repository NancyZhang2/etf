# ===========================================
# ETF量化投研平台 — 环境变量配置模板
# 复制为 .env 后填入真实值
# ===========================================

# ---------- 数据库 ----------
DATABASE_URL=postgresql+asyncpg://etf_user:your_password@localhost:5432/etf_quant

# ---------- Claude API ----------
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ---------- 微信公众号 ----------
WECHAT_APPID=wx_your_appid
WECHAT_APPSECRET=your_appsecret
WECHAT_TOKEN=your_token

# ---------- SMTP 邮件 ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password
SMTP_FROM=ETF量化平台 <your_email@example.com>

# ---------- 应用配置 ----------
LOG_LEVEL=INFO
BACKEND_PORT=8000
WEB_MANAGER_PORT=8080

# ---------- 数据库备份 ----------
BACKUP_DIR=/data/etf/backups
PG_HOST=localhost
PG_PORT=5432
PG_USER=etf_user
PG_DATABASE=etf_quant
